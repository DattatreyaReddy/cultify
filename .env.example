# Full curl command copied from browser devtools (Network tab -> any cult.fit
# API request -> Copy as cURL (bash)). Must be a single line (no backslashes).
CURL_COMMAND=curl 'https://www.cult.fit/api/user/cities/v2' -H 'apikey: ...' -b '...'

# Fallback city injected into cookies if the curl command doesn't already have one.
PREFERRED_CITY=bangalore

# Numeric ID of your preferred Cult.fit center. Default: 1515
PREFERRED_CENTER=607

# Comma-separated time slots (HH:MM:SS, 24h) to try in order. Default: 07:00:00,08:00:00,09:00:00
PREFERRED_SLOTS=21:00:00,20:00:00,19:00:00

# Comma-separated exact workout class name(s), in preference order. Default: HRX WORKOUT
PREFERRED_WORKOUT=HRX WORKOUT

# Join the waitlist when a class is full (skipped once 15+ people are already waitlisted).
ENABLE_WAITLIST=true
